{
  "name": "@latenode/code-sqlite-query",
  "version": "2.0.0",
  "type": "module",
  "description": "LateNode: SQLite query code node",
  "main": "./src/index.js",
  "types": "./src/types.d.ts",
  "exports": {
    ".": {
      "types": "./src/types.d.ts",
      "import": "./src/index.js"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "files": [
    "src/"
  ],
  "scripts": {
    "test": "bun test",
    "test:coverage": "bun test --coverage --coverage-reporter=lcov",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "publish:public": "npx --userconfig ~/.npmrc_latenode np --no-tests"
  },
  "engines": {
    "bun": ">=1.3.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/wmakeev/latenode-code-sqlite-query"
  },
  "author": {
    "name": "Vitaliy V. Makeev",
    "email": "w.makeev@gmail.com"
  },
  "license": "MIT",
  "prettier": {
    "semi": false,
    "singleQuote": true,
    "quoteProps": "consistent",
    "trailingComma": "none",
    "arrowParens": "avoid"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tsconfig/bun": "^1.0.10",
    "@tsconfig/strictest": "^2.0.8",
    "@types/bun": "^1.3.13",
    "eslint": "^10.2.1",
    "eslint-plugin-jsdoc": "^62.9.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  }
}
