{
  "extends": [
    "@tsconfig/bun/tsconfig.json",
    "@tsconfig/strictest/tsconfig.json"
  ],
  "compilerOptions": {
    "types": ["bun"],
    "noEmit": true,
    "allowJs": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true
  },
  "include": ["src/**/*", "test/**/*"]
}
